{
  "name": "mdeditor",
  "description": "Markdown editor client with local file support and Obsidian-style workflow",
  "author": "befar",
  "license": "MIT",
  "private": true,
  "version": "1.0.8",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:renderer": "vite --port 5174 --strictPort",
    "dev:desktop": "concurrently -k \"npm:dev:renderer\" \"wait-on http://localhost:5174 && cross-env VITE_DEV_SERVER_URL=http://localhost:5174 electron .\"",
    "build": "tsc -b && vite build",
    "start:desktop": "electron .",
    "dist:win": "node ./bump-version.cjs && npm run build && electron-builder --win nsis",
    "dist:win:ci": "npm run build && electron-builder --win nsis",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.1",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dompurify": "^3.4.11",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "marked-katex-extension": "^5.1.10",
    "mermaid": "^11.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "turndown": "^7.2.4",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.befar.mdeditor",
    "productName": "MdEditor",
    "electronLanguages": [
      "en-US",
      "zh-CN"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "HELP.md"
    ],
    "extraFiles": [
      {
        "from": "LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "NOTICE",
        "to": "NOTICE"
      },
      {
        "from": "THIRD_PARTY_LICENSES.md",
        "to": "THIRD_PARTY_LICENSES.md"
      },
      {
        "from": "HELP.md",
        "to": "HELP.md"
      },
      {
        "from": "plugins/svg-codeblock-renderer",
        "to": "plugins/svg-codeblock-renderer"
      },
      {
        "from": "plugins/obsidian-chart-plugin",
        "to": "plugins/obsidian-chart-plugin"
      }
    ],
    "extraMetadata": {
      "main": "electron/main.cjs",
      "dependencies": {},
      "optionalDependencies": {}
    },
    "win": {
      "icon": "build/icons/app.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "multiLanguageInstaller": true,
      "installerIcon": "build/icons/app.ico",
      "uninstallerIcon": "build/icons/app.ico",
      "installerHeaderIcon": "build/icons/app.ico",
      "installerLanguages": [
        "en_US",
        "zh_CN"
      ]
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown File",
        "description": "Markdown document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown File",
        "description": "Markdown document",
        "role": "Editor"
      }
    ]
  }
}
